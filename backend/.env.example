PORT=3333
# Em produção na VPS use 127.0.0.1 se o Apache/Nginx fizer proxy para esta porta
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=troque_por_um_segredo_longo_aleatorio
DATABASE_URL=postgresql://USUARIO:SENHA@localhost:5432/pizzaria?schema=public

# CORS: em desenvolvimento pode ficar vazio (API aceita qualquer origem).
# Em produção com NODE_ENV=production é OBRIGATÓRIO definir as URLs do frontend:
# CORS_ORIGIN=https://seudominio.com,https://www.seudominio.com

# Integração opcional (configurada pelo suporte): notificação ao criar pedido
# ORDER_WEBHOOK_URL=https://...
# ORDER_WEBHOOK_SECRET=...

# Rate limit (opcional)
# RATE_LIMIT_LOGIN_MAX=25
# RATE_LIMIT_PUBLIC_READ_MAX=300
# RATE_LIMIT_PUBLIC_ORDER_MAX=60

# Seed: em produção só roda se ALLOW_SEED=true (depois remova)
# ALLOW_SEED=true
