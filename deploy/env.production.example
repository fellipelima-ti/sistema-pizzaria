# Copie para .env na raiz do projeto (ao lado de docker-compose.prod.yml):
#   cp deploy/env.production.example .env
# Fluxo na ordem: deploy/FLUXO-VPS-COMPLETO.md
# Subir: ./deploy/vps-compose.sh   (na VPS, apos chmod +x deploy/vps-compose.sh)

# --- PostgreSQL (servico db) ---
POSTGRES_USER=postgres
POSTGRES_DB=pizzaria
# Use a MESMA senha abaixo na DATABASE_URL. So letras e numeros evita erro no .env (# corta linha).
POSTGRES_PASSWORD=troqueSenhaAlfanumerica123

# --- API (Prisma) ---
# Host deve ser "db" (nome do servico no Docker). Troque a senha pelo mesmo valor de POSTGRES_PASSWORD.
DATABASE_URL=postgresql://postgres:troqueSenhaAlfanumerica123@db:5432/pizzaria?schema=public

# Obrigatorio em producao: segredo longo e aleatorio (ex.: openssl rand -hex 32)
JWT_SECRET=troque_por_segredo_longo

# URLs exatas do painel no navegador (com https apos configurar TLS), separadas por virgula
# Ex.: https://pizzaria.cliente.com,https://www.pizzaria.cliente.com
CORS_ORIGIN=https://seudominio.com.br

# --- Site (HTTPS) ---
DOMAIN=seudominio.com.br
CADDY_EMAIL=seu-email@seudominio.com.br

# Seed (primeira vez): descomente, suba api, rode curl -X POST https://SEU_DOMINIO/api/seed, volte a comentar/false
# ALLOW_SEED=true

# Opcional: mais tentativas de login por IP (padrao 25 / 15 min)
# RATE_LIMIT_LOGIN_MAX=100
