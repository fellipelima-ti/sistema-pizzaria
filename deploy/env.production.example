# Copie para .env na raiz do projeto (ao lado de docker-compose.prod.yml)
# e ajuste os valores antes de: docker compose -f docker-compose.prod.yml up -d

# --- PostgreSQL (servico db) ---
POSTGRES_USER=postgres
POSTGRES_DB=pizzaria
POSTGRES_PASSWORD=troque_por_senha_forte

# --- API (Prisma) ---
# URL interna ao Docker (host = nome do servico "db")
DATABASE_URL=postgresql://postgres:troque_por_senha_forte@db:5432/pizzaria?schema=public

# Obrigatorio em producao: segredo longo e aleatorio (ex.: openssl rand -hex 32)
JWT_SECRET=troque_por_segredo_longo

# URLs exatas do painel no navegador (com https apos configurar TLS), separadas por virgula
# Ex.: https://pizzaria.cliente.com,https://www.pizzaria.cliente.com
CORS_ORIGIN=https://seudominio.com.br

# --- Site (HTTPS) ---
DOMAIN=seudominio.com.br
CADDY_EMAIL=seu-email@seudominio.com.br

# Opcional: seed inicial (admin + dados demo). Desligue apos primeiro uso: ALLOW_SEED=false ou remova
# ALLOW_SEED=true
